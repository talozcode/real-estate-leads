# -------------------------------------------------------
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# -------------------------------------------------------

# The email address of your Google service account.
# Example: leads-app@my-project-12345.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com

# The private key from your service account JSON key file.
# Copy the entire "private_key" value, including -----BEGIN/END----- lines.
# Replace every real newline with the two characters \n (backslash + n).
# Example: "-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----\n"
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END RSA PRIVATE KEY-----\n"

# The ID of your Google Sheet.
# Open the sheet in a browser. The URL looks like:
# https://docs.google.com/spreadsheets/d/THIS_IS_THE_ID/edit
# Copy just the long string between /d/ and /edit.
GOOGLE_SHEET_ID=your_google_sheet_id_here
